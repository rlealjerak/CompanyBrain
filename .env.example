# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=company_brain
POSTGRES_PASSWORD=change_me
POSTGRES_DB=company_brain

# Full DSN used by the API and Alembic (points to the Docker service name)
DATABASE_URL=postgresql://company_brain:change_me@postgres:5432/company_brain

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI Keys — BOTH are required ──────────────────────────────────────────────
# The system fails fast at startup if either key is missing.
ANTHROPIC_API_KEY=sk-ant-api03-...
VOYAGE_API_KEY=pa-...

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_string

# Set this before running `alembic upgrade head` to seed the first admin account.
# If not set, no admin user is created — run scripts/bootstrap_admin.py later.
ADMIN_BOOTSTRAP_PASSWORD=change_this_before_running_migrations

# ── Frontend ─────────────────────────────────────────────────────────────────
# Browser-visible API base URL (injected into the React bundle).
VITE_API_URL=http://localhost:8000
# Server-side proxy target for the Vite dev server.
# Inside Docker Compose this must be the service name; locally use localhost.
VITE_API_PROXY_TARGET=http://localhost:8000

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
